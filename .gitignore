# Ant runtime state (runs + staged diffs) — never committed
.ant/

# Built binary (root-anchored so it never matches cmd/ant/)
/ant

# goreleaser snapshot/release output
/dist/

# Node front-door dependencies + build output
adapters/*/node_modules/
adapters/*/dist/

# Go build/test artifacts
*.test
*.out
# Coverage reports only — NOT source. `coverage.*` previously also matched the
# real source file internal/engine/verify/testselect/coverage.go, silently
# keeping it out of the repo and breaking clean-checkout/CI builds.
coverage.html
coverage.txt
coverage.xml

# OS / editor cruft
.DS_Store

# Agent harness working state + project docs (kept local, not versioned)
.harness/
docs/
