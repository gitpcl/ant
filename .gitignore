# Ant runtime state (runs + staged diffs) — never committed
.ant/

# Built binary (root-anchored so it never matches cmd/ant/)
/ant

# goreleaser snapshot/release output
/dist/

# Node front-door dependencies + build output
adapters/*/node_modules/
adapters/*/dist/

# Go build/test artifacts
*.test
*.out
coverage.*

# OS / editor cruft
.DS_Store

# Agent harness working state + project docs (kept local, not versioned)
.harness/
docs/
